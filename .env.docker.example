# Docker Compose overrides — copy to .env when running the full stack with `docker compose --profile full up`
# Or merge these values into your .env

NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nestjs_saas
SMTP_HOST=mailhog
SMTP_PORT=1025
APP_URL=http://localhost:3000
RUN_SEED=true
