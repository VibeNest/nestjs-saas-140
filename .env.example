# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (matches docker-compose postgres service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_saas

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
OAUTH_EXCHANGE_SECRET=dev-oauth-exchange-secret-change-in-production
REFRESH_TOKEN_DELIVERY=cookie
BCRYPT_ROUNDS=10

# Auth
REQUIRE_EMAIL_VERIFICATION=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=Admin123!

# Rate limiting (auth routes have stricter per-route limits)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Email (Mailhog via docker-compose)
EMAIL_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=noreply@saas.com

# Google OAuth (set GOOGLE_OAUTH_ENABLED=true and real keys to enable)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# GitHub OAuth (set GITHUB_OAUTH_ENABLED=true and real keys to enable)
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# Stripe (disabled until you add real test keys from Stripe Dashboard)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel

# Docker production (set RUN_SEED=true on first deploy to create admin user)
RUN_SEED=false
