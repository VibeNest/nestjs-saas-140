# Test environment — auto-copied to .env.test by test:e2e script
NODE_ENV=test
PORT=3001
API_PREFIX=api/v1
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_saas_test

JWT_ACCESS_SECRET=test-access-secret-min-8-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-refresh-secret-min-8-chars
JWT_REFRESH_EXPIRES_IN=7d
OAUTH_EXCHANGE_SECRET=test-oauth-exchange-secret-min-8
REFRESH_TOKEN_DELIVERY=body
BCRYPT_ROUNDS=4

REQUIRE_EMAIL_VERIFICATION=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=Admin123!

THROTTLE_TTL=60000
THROTTLE_LIMIT=1000

EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=noreply@example.com

GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=test-github-client-id
GITHUB_CLIENT_SECRET=test-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_test_webhook_secret_for_e2e_tests_only
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel

RUN_SEED=false
